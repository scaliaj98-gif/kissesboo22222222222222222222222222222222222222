{
  "manifest_version": 3,
  "name": "SnapRecord Pro",
  "version": "2.0.0",
  "description": "Professional screen recording, screenshots & video editing. Like Loom but supercharged.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "downloads",
    "clipboardWrite",
    "desktopCapture",
    "tabCapture",
    "sidePanel",
    "alarms",
    "scripting",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SnapRecord Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "pages/sidebar.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*", "css/*", "js/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "pages/options.html",
  "commands": {
    "capture-visible": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Capture visible area"
    },
    "capture-full": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Capture full page"
    },
    "capture-region": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Capture selected region"
    },
    "start-recording": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Start/Stop screen recording"
    },
    "open-ai-assistant": {
      "suggested_key": { "default": "Alt+Shift+A" },
      "description": "Open AI Assistant sidebar"
    }
  }
}
